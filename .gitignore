# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be personal so it's back and forth.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a script/app, it's often package-dependent.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be either shared or ignored.
#   Refer to: https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be either shared or ignored.
#   Refer to: https://pdm-project.org/latest/usage/project/#commit-the-lock-file
#pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
/env/
/venv/
/ENV/
/env/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

